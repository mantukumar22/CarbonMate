{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "The user profile data",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique user ID" },
        "name": { "type": "string", "description": "The display name of the user" },
        "email": { "type": "string", "description": "The email address of the user" },
        "commutePref": { "type": "string", "description": "Preferred daily commute pattern" },
        "dietPref": { "type": "string", "description": "Preferred standard food diet" },
        "acPref": { "type": "string", "description": "Air conditioning usage habit" },
        "onboarded": { "type": "boolean", "description": "Whether onboarding has been completed" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of profile creation" }
      },
      "required": ["userId", "email"]
    },
    "DailyEntry": {
      "title": "DailyEntry",
      "description": "A daily footprint log entry for the user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique log entry ID" },
        "userId": { "type": "string", "description": "Owner userId of this daily log" },
        "date": { "type": "string", "description": "The log date (YYYY-MM-DD)" },
        "raw_text": { "type": "string", "description": "Original user written input description" },
        "transport": { "type": "array", "description": "Parsed transport modes and distances" },
        "food": { "type": "array", "description": "Parsed meal dishes and dietary choices" },
        "energy": { "type": "object", "description": "Electricity and air conditioning specifications" },
        "waste": { "type": "object", "description": "Recycling and waste count specifications" },
        "estimated_co2_kg": { "type": "number", "description": "Estimated aggregated CO2 emissions" },
        "notes": { "type": "string", "description": "EcoBuddy comments and encouraging recommendations" },
        "timestamp": { "type": "integer", "description": "Creation EPOCH time of this record" }
      },
      "required": ["id", "userId", "date", "raw_text", "estimated_co2_kg"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Storage for user registration profiles and preferences"
    },
    "/users/{userId}/entries/{entryId}": {
      "schema": "DailyEntry",
      "description": "Storage for carbon daily logs compiled for the user"
    }
  }
}
